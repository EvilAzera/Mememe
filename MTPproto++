#!/bin/bash
set -e

# Цвета
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${CYAN}🛡 Установка MTProto Proxy (Random Port + Yandex TLS + Auto Firewall)${NC}"

# 1. Зависимости
if ! command -v xxd &>/dev/null || ! command -v curl &>/dev/null; then
    apt-get update -qq && apt-get install -y -qq xxd curl >/dev/null 2>&1 || \
    yum install -y -q vim-common curl >/dev/null 2>&1
fi

# 2. Docker
if ! command -v docker &>/dev/null; then
    echo "🐳 Устанавливаю Docker..."
    curl -fsSL https://get.docker.com | sh >/dev/null 2>&1
    systemctl enable --now docker >/dev/null 2>&1
fi

# 3. Генерация случайного порта
PORT=$(shuf -i 10000-60000 -n 1)
while ss -tuln | grep -q ":$PORT "; do
    PORT=$(shuf -i 10000-60000 -n 1)
done
echo -e "🎲 Выбран случайный порт: ${GREEN}$PORT${NC}"

# 4. Настройка Firewall (открытие порта)
echo "🔥 Настройка брандмауэра..."
if command -v ufw &>/dev/null && ufw status | grep -q "active"; then
    ufw allow "$PORT"/tcp >/dev/null
    echo -e "   ✅ UFW: Порт $PORT открыт"
elif command -v firewall-cmd &>/dev/null; then
    firewall-cmd --permanent --add-port="$PORT"/tcp >/dev/null 2>&1
    firewall-cmd --reload >/dev/null 2>&1
    echo -e "   ✅ Firewalld: Порт $PORT открыт"
else
    echo -e "   ${YELLOW}⚠️  Брандмауэр не найден или не активен. Убедитесь, что порт $PORT открыт в панели управления хостингом.${NC}"
fi

# 5. Генерация секрета под Яндекс
DOMAIN="www.yandex.ru"
HEX_DOMAIN=$(echo -n "$DOMAIN" | xxd -p)
RAND_PART=$(head -c 16 /dev/urandom | xxd -ps -c 256 | tr -d '\n ')
SECRET="ee${RAND_PART}${HEX_DOMAIN}"

# 6. IP сервера
IP=$(curl -4 -s ifconfig.me || curl -4 -s icanhazip.com)

# 7. Конфиг и запуск
mkdir -p /etc/mtg
cat > /etc/mtg/config.toml <<EOF
secret = "${SECRET}"
bind-to = "0.0.0.0:3128"
prefer-ip = "prefer-ipv4"
concurrency = 8192

[network]
doh-ip = "1.1.1.1"
EOF

docker rm -f mtg >/dev/null 2>&1 || true

docker run -d \
    --name mtg \
    --restart always \
    -p "$PORT":3128 \
    -v /etc/mtg/config.toml:/config.toml:ro \
    nineseconds/mtg:2 run /config.toml >/dev/null

# 8. Вывод
LINK="https://t.me/proxy?server=${IP}&port=${PORT}&secret=${SECRET}"

echo -e "\n${GREEN}=========================================${NC}"
echo -e "✅ Готово! Прокси работает на порту $PORT"
echo -e "Маскировка под: $DOMAIN"
echo -e "\n${GREEN}📎 Ссылка для подключения:${NC}"
echo -e "${GREEN}$LINK${NC}"
echo -e "${GREEN}=========================================${NC}\n"
